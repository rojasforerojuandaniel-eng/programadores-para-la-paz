  "faq": {
    "title": "Frequently asked questions",
    "subtitle": "Clear answers about DIAN, security, payments and plans in Colombia.",
    "items": {
      "accountant": {
        "q": "Does Rhynode replace my accountant?",
        "a": "No. Rhynode automates repetitive tasks and organizes your information so you or your accountant work faster and with fewer errors."
      },
      "dian": {
        "q": "Is the invoicing valid with DIAN?",
        "a": "Yes. We generate electronic invoices with the structure DIAN requires and prepare the integration with authorized invoicing providers."
      },
      "payments": {
        "q": "Can I pay with Wompi, PSE or card?",
        "a": "Yes. Paid plans are processed with Wompi, letting you pay with PSE, credit/debit cards and other methods available in Colombia."
      },
      "personalOnly": {
        "q": "Can I use it only for personal finance?",
        "a": "Of course. The Starter plan is free forever and you can use it without activating business features."
      },
      "security": {
        "q": "Are my financial data safe?",
        "a": "We use encryption in transit and at rest, secure authentication and never sell your information. You own your data."
      },
      "price": {
        "q": "How much does it cost and are there lock-in contracts?",
        "a": "The Starter plan is free. Growth and Scale are monthly with no lock-in contracts or hidden fees. Cancel anytime."
      },
      "mobile": {
        "q": "Does it work on mobile?",
        "a": "Yes. Rhynode is a PWA, so you can use it from your phone browser, add it to your home screen and receive notifications."
      },
      "bank": {
        "q": "How do I connect my bank?",
        "a": "You can log transactions manually or connect accounts from Bancolombia, Davivienda, Nu, Nequi and other PSE/Wompi-compatible institutions."
      }
    }
  },
