# Required: Clerk publishable key for the mobile app.
# Get it from https://dashboard.clerk.com/ → your application → API keys.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Backend API URL that the mobile app talks to.
# Use the production deployment of the Rhynode Finance web app, e.g.:
#   https://rhynode-finance.vercel.app
EXPO_PUBLIC_API_URL=https://rhynode-finance.vercel.app

# Optional: Sentry DSN for crash reporting.
# Get it from https://sentry.io/ → Projects → Settings → Client Keys (DSN).
EXPO_PUBLIC_SENTRY_DSN=

# Optional: PostHog project API key for product analytics.
# Get it from https://us.posthog.com/ or https://eu.posthog.com/ → Project settings.
EXPO_PUBLIC_POSTHOG_KEY=

# Optional: PostHog host. Defaults to the US cloud endpoint.
# Use https://eu.i.posthog.com for EU projects.
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
