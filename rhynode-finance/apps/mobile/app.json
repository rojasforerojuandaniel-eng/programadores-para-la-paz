{
  "expo": {
    "name": "Rhynode",
    "slug": "rhynode-finance",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "rhynode",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "./assets/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rhynode.finance"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.rhynode.finance",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "rhynode",
              "host": "oauth-native-callback"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "organization": "rhynode",
          "project": "rhynode-finance-mobile"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "kotlinVersion": "2.0.21",
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Rhynode to access your camera to scan receipts."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Rhynode to use Face ID or fingerprint to secure your account."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c86c4e9c-c8a8-42d1-8243-1949949e0162"
      }
    }
  }
}
