# Expo local cache / generated files
.expo/
*.jsbundle

# Metro / build outputs
dist/
*.tsbuildinfo

# Native build outputs (covered by android/.gitignore and ios/.gitignore)
android/app/build/
android/build/
android/.gradle/
android/.cxx/
android/.kotlin/

# iOS build outputs if generated later
ios/Pods/
ios/build/

# Environment secrets
.env
.env.*
!.env.example

# Android signing keystores and credentials (never commit)
*.keystore
*.jks
*.credentials.properties

# Built APKs
*.apk

# Firebase Android configuration (contains API keys; never commit)
google-services.json

# Vendor directory used for pnpm workarounds (not source code)
vendor/
