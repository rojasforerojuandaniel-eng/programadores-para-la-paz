# Keep the Rhynode Finance monorepo
!/rhynode-finance/

# Dependencies
node_modules
.pnp
.pnp.js
.yarn/install-state.gz

# Build outputs
.next
out
dist
build
*.tsbuildinfo
next-env.d.ts

# Environment variables
.env
.env.local
.env.*.local
.env.vercel-check
.env*.local

# Vercel
.vercel

# Debug / logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS files
.DS_Store
*.pem
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Testing
coverage
.nyc_output
/test-results/
/playwright-report/
/playwright/.cache/
e2e/.auth/

# Prisma / DB
*.db
*.db-journal
prisma/migrations/*/migration_lock.toml

# clerk configuration (can include secrets)
/.clerk/
