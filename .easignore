# Ignore all top-level home entries except rhynode-finance

/*
!/rhynode-finance

# Also ignore everything inside rhynode-finance that should not be uploaded
rhynode-finance/.git
rhynode-finance/node_modules
rhynode-finance/.next
rhynode-finance/out
rhynode-finance/dist
rhynode-finance/build
rhynode-finance/.vercel
rhynode-finance/.env*
